<!--
  Global sidebar (neon rail) — included on every page (home + games), it
  replaces the old footer. A compact 64px rail of super-category tiles (Action,
  Puzzle, Words, Quiz, Board); hovering a tile unfolds a flyout listing that
  category's games (on mobile the rail slides in via .sidebar-toggle and the
  categories become tap-to-open accordions). The active game is marked in JS
  (.is-active) from the URL and its category tile gets .has-active. Each game
  link is tinted with its accent via --nav-accent (from the game's `color`
  token) and shows a small mode badge (solo / duo / multi) from `data-mode`.
-->
<button
  class="sidebar-toggle"
  type="button"
  aria-label="Open menu"
  aria-expanded="false"
>
  <i class="fas fa-bars" aria-hidden="true"></i>
</button>
<div class="sidebar-scrim" hidden></div>
<nav class="sidebar" aria-label="Games navigation">
  <a class="sidebar-brand" href="/" data-nav="home">
    <span class="sidebar-icon"><i class="fas fa-gamepad" aria-hidden="true"></i></span>
    <span class="sidebar-label">Games Zone</span>
  </a>
  <ul class="sidebar-nav">
    {{#each categories}}
    <li class="sidebar-cat" data-cat="{{id}}" style="--cat-accent: var({{color}})">
      <button
        class="sidebar-cat-head"
        type="button"
        aria-expanded="false"
        aria-label="{{label}}"
      >
        <span class="sidebar-icon"><i class="fas {{icon}}" aria-hidden="true"></i></span>
        <span class="sidebar-label" data-i18n="cat_{{id}}">{{label}}</span>
        <span class="sidebar-cat-caret" aria-hidden="true"><i class="fas fa-chevron-right"></i></span>
      </button>
      <div class="sidebar-flyout">
        <p class="sidebar-flyout-title" data-i18n="cat_{{id}}">{{label}}</p>
        <ul class="sidebar-cat-games">
          {{#each games}}
          <li>
            <a
              class="sidebar-link"
              href="/{{key}}"
              data-nav="{{key}}"
              style="--nav-accent: var({{color}})"
            >
              <span class="sidebar-icon"><span class="game-icon" style="--game-icon: url(/icons/{{key}}.svg)" aria-hidden="true"></span></span>
              <span class="sidebar-label" data-i18n="game_{{key}}">{{label}}</span>
              {{#if mode}}<span class="sidebar-mode" data-mode="{{mode}}" title="{{mode}}" aria-hidden="true"></span>{{/if}}
            </a>
          </li>
          {{/each}}
        </ul>
      </div>
    </li>
    {{/each}}
  </ul>
  <div class="sidebar-auth" id="authArea"></div>
</nav>
<!-- Language toggle: fixed top-right, left of the sound bubble. Text (EN/FR)
     rather than a flag emoji, which doesn't render on Windows. -->
<button class="lang-toggle" id="langToggle" type="button" aria-label="Language">
  <span id="langCode">EN</span>
</button>
<!-- Sound toggle: fixed top-right bubble, visible on all pages. -->
<button class="sound-toggle" id="soundToggle" type="button" aria-label="Mute sound">
  <i class="fas fa-volume-high" id="soundIcon" aria-hidden="true"></i>
  <span class="sound-toggle-ring" aria-hidden="true"></span>
</button>
<script type="module" src="/shared/ui/sidebar.ts"></script>
<script type="module" src="/shared/net/login.ts"></script>
