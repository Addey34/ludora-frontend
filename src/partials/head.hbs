<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="google-site-verification" content="I47NAck2mGIgagvVnUFDguOzis2FRTpRF5AEvjjftIg" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/favicon.svg" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#4361ee" />
  <title>{{title}}</title>
  <meta name="description" content="{{metaDescription}}" />
  <link rel="canonical" href="{{canonical}}" />
  <!-- Locale alternates. Identical on the EN and FR variants; translateHtml only
       rewrites <html lang>, canonical and og:url for the FR page. -->
  <link rel="alternate" hreflang="en" href="{{altEn}}" />
  <link rel="alternate" hreflang="fr" href="{{altFr}}" />
  <link rel="alternate" hreflang="x-default" href="{{altEn}}" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Ludora" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:url" content="{{canonical}}" />
  <meta property="og:title" content="{{title}}" />
  <meta property="og:description" content="{{metaDescription}}" />
  <meta property="og:image" content="{{site}}/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{title}}" />
  <meta name="twitter:description" content="{{metaDescription}}" />
  <meta name="twitter:image" content="{{site}}/og-image.png" />
  <script>
    (function () {
      var themes = ['arcade', 'midnight', 'daylight', 'amber'];
      var storageKey = 'gz-theme';
      var params = new URLSearchParams(window.location.search);
      var requested = params.get('theme');
      var stored = null;
      try {
        stored = localStorage.getItem(storageKey);
      } catch (error) {}
      var theme = themes.indexOf(requested) !== -1 ? requested : themes.indexOf(stored) !== -1 ? stored : 'arcade';
      document.documentElement.dataset.uiTheme = theme;
      if (themes.indexOf(requested) !== -1) {
        try {
          localStorage.setItem(storageKey, theme);
        } catch (error) {}
      }
    })();
  </script>
  <link rel="stylesheet" href="{{css}}" />
  <!-- Landscape boards: a game declaring `board: { fit }` in the games array
       widens its shell into a proper table frame. Set at :root here (the frame
       width is computed on .app-body, which can't see a child override) so the
       game needs no :root block of its own — see game-layout.css `.game-board--fill`. -->
  {{#if game.board.fit}}<style>:root { --game-board-fit-ratio: {{game.board.fit}} }</style>{{/if}}
  <!-- Font Awesome, self-hosted and subset to only the icons we use (see
       scripts/build-icons.mjs — `npm run icons`): ~3 KB of CSS + the solid
       woff2, no render-blocking CDN request, cacheable by the service worker. -->
  <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css" />
  {{#if script}}<script type="module" src="{{script}}"></script>{{/if}}
  <script type="application/ld+json">{{{ldJson}}}</script>
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', function () {
        navigator.serviceWorker.register('/sw.js').catch(function () {});
      });
    }
  </script>
  <!-- Cloudflare Web Analytics: cookieless (no consent banner needed), deferred
       so it never blocks rendering. Public beacon token, safe client-side. -->
  <script
    defer
    src="https://static.cloudflareinsights.com/beacon.min.js"
    data-cf-beacon='{"token": "e012ee0f6762466c8a00b9d5117630a4"}'
  ></script>
</head>
