<!--
  Opening of the unified page shell, shared by every game: a single container
  (.game-shell) wrapping the title and then the game's own content.
  Parameters:
    - title : the title text.
    - key   : the game key (e.g. snake); shows its SVG logo (/icons/<key>.svg) on
              both sides of the title (optional).
  Close it with the shell-close partial.
-->
<main class="game-container"{{#if game}} style="--title-color: var({{game.color}})"{{/if}}>
  <section class="game-shell">
    <h1 class="app-title">
      {{#if key}}<span class="game-icon" style="--game-icon: url(/icons/{{key}}.svg)" aria-hidden="true"></span>{{/if}}
      {{#if key}}<span data-i18n="game_{{key}}">{{title}}</span>{{else}}{{title}}{{/if}}
      {{#if key}}<span class="game-icon" style="--game-icon: url(/icons/{{key}}.svg)" aria-hidden="true"></span>{{/if}}
    </h1>
    {{#if game}}
    <!-- Action bar, top-left corner: levels (optional), help, then leaderboard. -->
    <div class="game-actions">
      {{#if game.controls}}
      <!-- Help: panel revealed on hover (or keyboard focus / mobile tap), pure CSS. -->
      <div class="game-info">
        <button
          class="game-info-toggle"
          type="button"
          aria-label="Help: how to play"
          aria-controls="gameInfoPanel"
        >
          <i class="fas fa-circle-info" aria-hidden="true"></i>
        </button>
        <div class="game-info-panel" id="gameInfoPanel" role="dialog" aria-label="How to play">
          <h2 class="game-info-title" data-i18n="howToPlay">How to play</h2>
          <ul class="game-info-list">
            {{#each game.controls}}
            <li class="game-info-item">
              <span class="game-info-keys">{{{this.keys}}}</span>
              <span class="game-info-action">{{this.action}}</span>
            </li>
            {{/each}}
          </ul>
        </div>
      </div>
      {{/if}}
      {{#if game.settings}}
      <!-- Settings: options popover (filled by settingsPanel.ts, e.g. bot difficulty). -->
      <div class="game-pop" id="settingsControl">
        <button
          class="game-pop-toggle"
          type="button"
          id="settingsToggle"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="settingsPanel"
          aria-label="Settings"
        >
          <i class="fas fa-sliders" aria-hidden="true"></i>
        </button>
        <div class="game-pop-panel" id="settingsPanel" role="dialog" aria-label="Settings"></div>
      </div>
      {{/if}}
      {{#if game.levels}}
      <!-- Levels: compact icon button, expands the panel on click (filled by levelPanel.ts). -->
      <div class="game-pop" id="levelControl">
        <button
          class="game-pop-toggle"
          type="button"
          id="levelToggle"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="levelPanel"
          aria-label="Levels"
        >
          <i class="fas fa-layer-group" aria-hidden="true"></i>
          <span class="game-pop-current" aria-hidden="true">1</span>
        </button>
        <div class="game-pop-panel" id="levelPanel" role="dialog" aria-label="Choose a level"></div>
      </div>
      {{/if}}
      {{#if game.leaderboard}}
      <!-- Leaderboard: same popover, holds the score table (filled by the engine). -->
      <div class="game-pop" id="leaderboardControl">
        <button
          class="game-pop-toggle"
          type="button"
          id="leaderboardToggle"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="leaderboardPanel"
          aria-label="Leaderboard"
        >
          <i class="fas fa-trophy" aria-hidden="true"></i>
        </button>
        <div
          class="game-pop-panel game-leaderboard-panel"
          id="leaderboardPanel"
          role="dialog"
          aria-label="Leaderboard"
        >
          <p class="game-pop-title">Leaderboard</p>
          <table id="scoreTable" class="score-table">
            <thead>
              <tr>
                <th>Player</th>
                <th>Score</th>
                {{#if game.speed}}<th>Speed</th>{{/if}}
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
      {{/if}}
      {{#if game.multiplayer}}
      <!-- Multiplayer: session popover (create / join by code), filled by multiplayerPanel.ts. -->
      <div class="game-pop" id="multiplayerControl">
        <button
          class="game-pop-toggle"
          type="button"
          id="multiplayerToggle"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="multiplayerPanel"
          aria-label="Multiplayer"
        >
          <i class="fas fa-users" aria-hidden="true"></i>
        </button>
        <div
          class="game-pop-panel game-multiplayer-panel"
          id="multiplayerPanel"
          role="dialog"
          aria-label="Multiplayer"
        ></div>
      </div>
      {{/if}}
    </div>
    <button class="game-fullscreen-toggle" type="button" aria-label="Immersive mode" aria-pressed="false">
      <i class="fas fa-expand" aria-hidden="true"></i>
    </button>
    <script type="module" src="/shared/ui/zenMode.ts"></script>
    {{/if}}
